{
  "name": "saizeriya",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --cwd packages/server --watch src/main.ts",
    "cli": "bun --cwd packages/client cli.ts",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "check": "vp check .",
    "check:fix": "vp check --fix",
    "test": "vp test",
    "test:watch": "vp test watch"
  },
  "dependencies": {
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "vite-plus": "^0.1.20"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
