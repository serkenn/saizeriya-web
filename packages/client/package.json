{
  "name": "saizeriya.js",
  "version": "0.0.1",
  "description": "A research client library and CLI for Saizeriya's mobile ordering flow.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsk-lab/saizeriya.git",
    "directory": "packages/client"
  },
  "bin": {
    "saizeriya": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./browser-mode": {
      "types": "./dist/browser-mode.d.mts",
      "import": "./dist/browser-mode.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack index.ts browser-mode.ts cli.ts --dts --clean",
    "pack": "vp pack index.ts browser-mode.ts cli.ts --dts --clean",
    "cli": "bun cli.ts",
    "test": "vp test",
    "test:watch": "vp test watch"
  },
  "dependencies": {
    "node-html-parser": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "playwright": "^1.57.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "optionalDependencies": {
    "playwright": "^1.57.0"
  }
}
